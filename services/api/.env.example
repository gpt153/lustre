DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lustre
PORT=4000
HOST=0.0.0.0
JWT_SECRET=your-secret-key-here-change-in-production
REDIS_URL=redis://localhost:6379
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=your-meilisearch-master-key
NATS_URL=nats://localhost:4222
NODE_ENV=development
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
CORS_ORIGINS=https://app.lovelustre.com,https://pay.lovelustre.com,https://admin.lovelustre.com

# Payment webhook secrets — REQUIRED in production.
# Set to the HMAC-SHA256 shared secret configured in the payment provider dashboard.
# In development, leave blank to skip verification (NODE_ENV !== production).
SWISH_WEBHOOK_SECRET=
SEGPAY_WEBHOOK_SECRET=
