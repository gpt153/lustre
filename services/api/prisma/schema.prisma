generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis, vector]
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DELETED
}

enum PaymentStatus {
  PENDING
  PAID
  DECLINED
  ERROR
}

enum Gender {
  MAN
  WOMAN
  NON_BINARY
  TRANS_MAN
  TRANS_WOMAN
  GENDERQUEER
  GENDERFLUID
  AGENDER
  BIGENDER
  TWO_SPIRIT
  OTHER
}

enum Orientation {
  STRAIGHT
  GAY
  LESBIAN
  BISEXUAL
  PANSEXUAL
  QUEER
  ASEXUAL
  DEMISEXUAL
  OTHER
}

enum RelationshipType {
  SINGLE
  PARTNERED
  MARRIED
  OPEN_RELATIONSHIP
  POLYAMOROUS
  OTHER
}

enum Seeking {
  FRIENDSHIP
  DATING
  CASUAL
  RELATIONSHIP
  PLAY_PARTNER
  NETWORKING
  OTHER
}

enum ContentPreference {
  SOFT
  OPEN
  EXPLICIT
  NO_DICK_PICS
}

enum KinkInterestLevel {
  CURIOUS
  LIKE
  LOVE
}

model User {
  id                 String            @id @default(uuid()) @db.Uuid
  displayName        String?           @map("display_name")
  personnummerHash   String            @unique @map("personnummer_hash")
  status             UserStatus        @default(PENDING)
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  encryptedIdentity  EncryptedIdentity?
  sessions           Session[]
  payments           Payment[]
  profile            Profile?

  @@map("users")
}

model EncryptedIdentity {
  id                     String   @id @default(uuid()) @db.Uuid
  userId                 String   @unique @db.Uuid @map("user_id")
  encryptedFirstName     String   @map("encrypted_first_name")
  encryptedLastName      String   @map("encrypted_last_name")
  encryptedPersonnummer  String   @map("encrypted_personnummer")
  iv                     String
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("encrypted_identities")
}

model Session {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid @map("user_id")
  tokenHash String    @unique @map("token_hash")
  deviceInfo String?   @map("device_info")
  ipAddress String?   @map("ip_address")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Payment {
  id             String        @id @default(uuid()) @db.Uuid
  userId         String        @db.Uuid @map("user_id")
  swishPaymentId String?       @unique @map("swish_payment_id")
  amount         Decimal       @db.Decimal(10, 2)
  currency       String        @default("SEK")
  status         PaymentStatus @default(PENDING)
  swishToken     String?       @map("swish_token")
  createdAt      DateTime      @default(now()) @map("created_at")
  completedAt    DateTime?     @map("completed_at")
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Profile {
  id                String            @id @default(uuid()) @db.Uuid
  userId            String            @unique @db.Uuid @map("user_id")
  displayName       String            @map("display_name")
  bio               String?
  age               Int
  gender            Gender
  orientation       Orientation
  relationshipType  RelationshipType? @map("relationship_type")
  seeking           Seeking[]
  contentPreference ContentPreference @map("content_preference")
  verified          Boolean           @default(false)
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  photos            ProfilePhoto[]
  kinkTags          ProfileKinkTag[]

  @@map("profiles")
}

model ProfilePhoto {
  id              String   @id @default(uuid()) @db.Uuid
  profileId       String   @db.Uuid @map("profile_id")
  url             String
  thumbnailSmall  String?  @map("thumbnail_small")
  thumbnailMedium String?  @map("thumbnail_medium")
  thumbnailLarge  String?  @map("thumbnail_large")
  position        Int      @default(0)
  isPublic        Boolean  @default(true) @map("is_public")
  createdAt       DateTime @default(now()) @map("created_at")
  profile         Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("profile_photos")
}

model KinkTag {
  id        String           @id @default(uuid()) @db.Uuid
  name      String           @unique
  category  String
  createdAt DateTime         @default(now()) @map("created_at")
  profiles  ProfileKinkTag[]

  @@map("kink_tags")
}

model ProfileKinkTag {
  id            String            @id @default(uuid()) @db.Uuid
  profileId     String            @db.Uuid @map("profile_id")
  kinkTagId     String            @db.Uuid @map("kink_tag_id")
  interestLevel KinkInterestLevel @map("interest_level")
  isPublic      Boolean           @default(true) @map("is_public")
  profile       Profile           @relation(fields: [profileId], references: [id], onDelete: Cascade)
  kinkTag       KinkTag           @relation(fields: [kinkTagId], references: [id], onDelete: Cascade)

  @@unique([profileId, kinkTagId])
  @@map("profile_kink_tags")
}
