generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis, vector]
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DELETED
}

enum PaymentStatus {
  PENDING
  PAID
  DECLINED
  ERROR
}

enum Gender {
  MAN
  WOMAN
  NON_BINARY
  TRANS_MAN
  TRANS_WOMAN
  GENDERQUEER
  GENDERFLUID
  AGENDER
  BIGENDER
  TWO_SPIRIT
  OTHER
}

enum Orientation {
  STRAIGHT
  GAY
  LESBIAN
  BISEXUAL
  PANSEXUAL
  QUEER
  ASEXUAL
  DEMISEXUAL
  OTHER
}

enum RelationshipType {
  SINGLE
  PARTNERED
  MARRIED
  OPEN_RELATIONSHIP
  POLYAMOROUS
  OTHER
}

enum Seeking {
  FRIENDSHIP
  DATING
  CASUAL
  RELATIONSHIP
  PLAY_PARTNER
  NETWORKING
  OTHER
}

enum ContentPreference {
  SOFT
  OPEN
  EXPLICIT
  NO_DICK_PICS
}

enum KinkInterestLevel {
  CURIOUS
  LIKE
  LOVE
}

model User {
  id                 String            @id @default(uuid()) @db.Uuid
  displayName        String?           @map("display_name")
  personnummerHash   String            @unique @map("personnummer_hash")
  status             UserStatus        @default(PENDING)
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  encryptedIdentity  EncryptedIdentity?
  sessions           Session[]
  payments           Payment[]
  profile            Profile?
  posts              Post[]
  contentFilter      UserContentFilter?
  feedInteractions   FeedInteraction[]
  groupsCreated      Group[]           @relation("groupsCreated")
  groupMemberships   GroupMember[]
  groupModerators    GroupModerator[]

  @@map("users")
}

model EncryptedIdentity {
  id                     String   @id @default(uuid()) @db.Uuid
  userId                 String   @unique @db.Uuid @map("user_id")
  encryptedFirstName     String   @map("encrypted_first_name")
  encryptedLastName      String   @map("encrypted_last_name")
  encryptedPersonnummer  String   @map("encrypted_personnummer")
  iv                     String
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("encrypted_identities")
}

model Session {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid @map("user_id")
  tokenHash String    @unique @map("token_hash")
  deviceInfo String?   @map("device_info")
  ipAddress String?   @map("ip_address")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Payment {
  id             String        @id @default(uuid()) @db.Uuid
  userId         String        @db.Uuid @map("user_id")
  swishPaymentId String?       @unique @map("swish_payment_id")
  amount         Decimal       @db.Decimal(10, 2)
  currency       String        @default("SEK")
  status         PaymentStatus @default(PENDING)
  swishToken     String?       @map("swish_token")
  createdAt      DateTime      @default(now()) @map("created_at")
  completedAt    DateTime?     @map("completed_at")
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Profile {
  id                String            @id @default(uuid()) @db.Uuid
  userId            String            @unique @db.Uuid @map("user_id")
  displayName       String            @map("display_name")
  bio               String?
  age               Int
  gender            Gender
  orientation       Orientation
  relationshipType  RelationshipType? @map("relationship_type")
  seeking           Seeking[]
  contentPreference ContentPreference @map("content_preference")
  verified          Boolean           @default(false)
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  photos              ProfilePhoto[]
  kinkTags            ProfileKinkTag[]
  invitationsSent     PairInvitation[] @relation("invitationsSent")
  invitationsReceived PairInvitation[] @relation("invitationsReceived")
  pairLinkMembers     PairLinkMember[]

  @@map("profiles")
}

model ProfilePhoto {
  id              String   @id @default(uuid()) @db.Uuid
  profileId       String   @db.Uuid @map("profile_id")
  url             String
  thumbnailSmall  String?  @map("thumbnail_small")
  thumbnailMedium String?  @map("thumbnail_medium")
  thumbnailLarge  String?  @map("thumbnail_large")
  position        Int      @default(0)
  isPublic        Boolean  @default(true) @map("is_public")
  createdAt       DateTime @default(now()) @map("created_at")
  profile         Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("profile_photos")
}

model KinkTag {
  id        String           @id @default(uuid()) @db.Uuid
  name      String           @unique
  category  String
  createdAt DateTime         @default(now()) @map("created_at")
  profiles  ProfileKinkTag[]

  @@map("kink_tags")
}

model ProfileKinkTag {
  id            String            @id @default(uuid()) @db.Uuid
  profileId     String            @db.Uuid @map("profile_id")
  kinkTagId     String            @db.Uuid @map("kink_tag_id")
  interestLevel KinkInterestLevel @map("interest_level")
  isPublic      Boolean           @default(true) @map("is_public")
  profile       Profile           @relation(fields: [profileId], references: [id], onDelete: Cascade)
  kinkTag       KinkTag           @relation(fields: [kinkTagId], references: [id], onDelete: Cascade)

  @@unique([profileId, kinkTagId])
  @@map("profile_kink_tags")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

model PairInvitation {
  id            String           @id @default(uuid()) @db.Uuid
  fromProfileId String           @db.Uuid @map("from_profile_id")
  toProfileId   String           @db.Uuid @map("to_profile_id")
  status        InvitationStatus @default(PENDING)
  createdAt     DateTime         @default(now()) @map("created_at")
  expiresAt     DateTime         @map("expires_at")
  fromProfile   Profile          @relation("invitationsSent", fields: [fromProfileId], references: [id], onDelete: Cascade)
  toProfile     Profile          @relation("invitationsReceived", fields: [toProfileId], references: [id], onDelete: Cascade)

  @@map("pair_invitations")
}

model PairLink {
  id        String           @id @default(uuid()) @db.Uuid
  createdAt DateTime         @default(now()) @map("created_at")
  members   PairLinkMember[]

  @@map("pair_links")
}

model PairLinkMember {
  id         String   @id @default(uuid()) @db.Uuid
  pairLinkId String   @db.Uuid @map("pair_link_id")
  profileId  String   @db.Uuid @map("profile_id")
  joinedAt   DateTime @default(now()) @map("joined_at")
  pairLink   PairLink @relation(fields: [pairLinkId], references: [id], onDelete: Cascade)
  profile    Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([pairLinkId, profileId])
  @@map("pair_link_members")
}

enum NudityLevel {
  NONE
  IMPLIED
  PARTIAL
  FULL
}

enum BodyPartTag {
  FACE
  CHEST
  BACK
  BUTT
  GENITALS
  LEGS
  FEET
  FULL_BODY
}

enum ActivityTag {
  SELFIE
  MIRROR
  OUTDOOR
  GYM
  BEDROOM
  ARTISTIC
  COUPLE
  GROUP
}

enum VibeTag {
  CASUAL
  SENSUAL
  PLAYFUL
  INTENSE
  ROMANTIC
  ARTISTIC
}

enum GenderPresentationTag {
  MASCULINE
  FEMININE
  ANDROGYNOUS
  MIXED
}

enum ContentTagDimension {
  NUDITY
  BODY_PART
  ACTIVITY
  VIBE
  GENDER_PRESENTATION
}

model Post {
  id           String            @id @default(uuid()) @db.Uuid
  authorId     String            @db.Uuid @map("author_id")
  text         String?           @db.VarChar(2000)
  groupId      String?           @db.Uuid @map("group_id")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  author       User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  group        Group?            @relation("groupPosts", fields: [groupId], references: [id], onDelete: SetNull)
  media        PostMedia[]
  interactions FeedInteraction[]

  @@map("posts")
}

model PostMedia {
  id              String       @id @default(uuid()) @db.Uuid
  postId          String       @db.Uuid @map("post_id")
  url             String
  thumbnailSmall  String?      @map("thumbnail_small")
  thumbnailMedium String?      @map("thumbnail_medium")
  thumbnailLarge  String?      @map("thumbnail_large")
  position        Int          @default(0)
  createdAt       DateTime     @default(now()) @map("created_at")
  post            Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  tags            ContentTag[]

  @@map("post_media")
}

model ContentTag {
  id          String              @id @default(uuid()) @db.Uuid
  postMediaId String              @db.Uuid @map("post_media_id")
  dimension   ContentTagDimension
  value       String
  confidence  Float               @default(1.0)
  createdAt   DateTime            @default(now()) @map("created_at")
  postMedia   PostMedia           @relation(fields: [postMediaId], references: [id], onDelete: Cascade)

  @@map("content_tags")
}

model UserContentFilter {
  id                  String                  @id @default(uuid()) @db.Uuid
  userId              String                  @unique @db.Uuid @map("user_id")
  nudityLevel         NudityLevel[]           @map("nudity_level")
  bodyPart            BodyPartTag[]           @map("body_part")
  activity            ActivityTag[]
  vibe                VibeTag[]
  genderPresentation  GenderPresentationTag[] @map("gender_presentation")
  preset              ContentPreference
  updatedAt           DateTime                @updatedAt @map("updated_at")
  user                User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_content_filters")
}

enum FeedInteractionType {
  LIKE
  SHOW_LESS
}

model FeedInteraction {
  id        String              @id @default(uuid()) @db.Uuid
  userId    String              @db.Uuid @map("user_id")
  postId    String              @db.Uuid @map("post_id")
  type      FeedInteractionType
  createdAt DateTime            @default(now()) @map("created_at")
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post                @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId, type])
  @@map("feed_interactions")
}

enum GroupVisibility {
  OPEN
  PRIVATE
}

enum MembershipStatus {
  PENDING
  ACTIVE
  BANNED
}

enum ModeratorRole {
  MODERATOR
  OWNER
}

model Group {
  id            String          @id @default(uuid()) @db.Uuid
  name          String          @db.VarChar(100)
  description   String?         @db.VarChar(2000)
  category      String          @db.VarChar(100)
  visibility    GroupVisibility  @default(OPEN)
  coverImageUrl String?         @map("cover_image_url")
  createdById   String          @db.Uuid @map("created_by_id")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  creator       User            @relation("groupsCreated", fields: [createdById], references: [id], onDelete: Cascade)
  members       GroupMember[]
  moderators    GroupModerator[]
  posts         Post[]          @relation("groupPosts")

  @@map("groups")
}

model GroupMember {
  id        String           @id @default(uuid()) @db.Uuid
  groupId   String           @db.Uuid @map("group_id")
  userId    String           @db.Uuid @map("user_id")
  status    MembershipStatus @default(ACTIVE)
  joinedAt  DateTime         @default(now()) @map("joined_at")
  group     Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_members")
}

model GroupModerator {
  id         String        @id @default(uuid()) @db.Uuid
  groupId    String        @db.Uuid @map("group_id")
  userId     String        @db.Uuid @map("user_id")
  role       ModeratorRole
  assignedAt DateTime      @default(now()) @map("assigned_at")
  group      Group         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_moderators")
}
