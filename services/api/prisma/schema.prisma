generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DELETED
}

enum PaymentStatus {
  PENDING
  PAID
  DECLINED
  ERROR
}

model User {
  id                 String            @id @default(uuid()) @db.Uuid
  displayName        String?           @map("display_name")
  personnummerHash   String            @unique @map("personnummer_hash")
  status             UserStatus        @default(PENDING)
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  encryptedIdentity  EncryptedIdentity?
  sessions           Session[]
  payments           Payment[]

  @@map("users")
}

model EncryptedIdentity {
  id                     String   @id @default(uuid()) @db.Uuid
  userId                 String   @unique @db.Uuid @map("user_id")
  encryptedFirstName     String   @map("encrypted_first_name")
  encryptedLastName      String   @map("encrypted_last_name")
  encryptedPersonnummer  String   @map("encrypted_personnummer")
  iv                     String
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("encrypted_identities")
}

model Session {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid @map("user_id")
  tokenHash String    @unique @map("token_hash")
  deviceInfo String?   @map("device_info")
  ipAddress String?   @map("ip_address")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Payment {
  id             String        @id @default(uuid()) @db.Uuid
  userId         String        @db.Uuid @map("user_id")
  swishPaymentId String?       @unique @map("swish_payment_id")
  amount         Decimal       @db.Decimal(10, 2)
  currency       String        @default("SEK")
  status         PaymentStatus @default(PENDING)
  swishToken     String?       @map("swish_token")
  createdAt      DateTime      @default(now()) @map("created_at")
  completedAt    DateTime?     @map("completed_at")
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payments")
}
