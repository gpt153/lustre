generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis, vector]
}

model User {
  id                         String                    @id @default(uuid()) @db.Uuid
  email                      String?                   @unique
  passwordHash               String?                   @map("password_hash")
  displayName                String?                   @map("display_name")
  personnummer_hash          String                    @unique
  status                     UserStatus                @default(PENDING)
  createdAt                  DateTime                  @default(now()) @map("created_at")
  updatedAt                  DateTime                  @updatedAt @map("updated_at")
  initiatedCalls             CallSession[]             @relation("CallInitiator")
  receivedCalls              CallSession[]             @relation("CallReceiver")
  coachSessions              CoachSession[]
  consentRecordsInitiated    ConsentRecord[]           @relation("consentInitiator")
  consentRecordsParticipated ConsentRecord[]           @relation("consentParticipant")
  conversationParticipants   ConversationParticipant[]
  encryptedIdentity          EncryptedIdentity?
  eventAttendances           EventAttendee[]
  eventTickets               EventTicket[]             @relation("eventTickets")
  eventsCreated              Event[]                   @relation("eventsCreated")
  feedInteractions           FeedInteraction[]
  gatekeeperConfig           GatekeeperConfig?         @relation("gatekeeperConfig")
  gatekeeperReceived         GatekeeperConversation[]  @relation("gatekeeperReceived")
  gatekeeperSent             GatekeeperConversation[]  @relation("gatekeeperSent")
  groupMemberships           GroupMember[]
  groupModerators            GroupModerator[]
  groupsCreated              Group[]                   @relation("groupsCreated")
  matchesAsUser1             Match[]                   @relation("matchesAsUser1")
  matchesAsUser2             Match[]                   @relation("matchesAsUser2")
  messagesSent               Message[]
  orgMemberships             OrgMember[]
  orgsCreated                Organization[]            @relation("orgsCreated")
  payments                   Payment[]
  posts                      Post[]
  profile                    Profile?
  recordingAccesses          RecordingAccess[]
  recordingRevocations       RecordingRevocation[]
  safeDates                  SafeDate[]
  seenProfileTargets         SeenProfile[]             @relation("seenProfileTargets")
  seenProfiles               SeenProfile[]             @relation("seenProfiles")
  sessions                   Session[]
  swipesReceived             Swipe[]                   @relation("swipesReceived")
  swipesSent                 Swipe[]                   @relation("swipesSent")
  tokenTransactions          TokenTransaction[]
  userBadges                 UserBadge[]
  userBalance                UserBalance?
  swishAgreement             SwishRecurringAgreement?
  segpayCards                SegpayCard[]
  segpayTransactions         SegpayTransaction[]
  contentFilter              UserContentFilter?
  lessonProgress             UserLessonProgress[]
  userMedals                 UserMedal[]
  moduleProgress             UserModuleProgress[]
  userStreak                 UserStreak?
  filteredSentCount          Int                       @default(0) @map("filtered_sent_count")
  warningCount               Int                       @default(0) @map("warning_count")
  isBanned                   Boolean                   @default(false) @map("is_banned")
  bannedUntil                DateTime?                 @map("banned_until")
  reportsMade                Report[]                  @relation("reportsMade")
  moderationActions          ModerationAction[]        @relation("moderationActions")
  inviteLinks                InviteLink[]
  referralRewardsGiven       ReferralReward[]          @relation("ReferralGiven")
  referralRewardsReceived    ReferralReward[]          @relation("ReferralReceived")
  kudosGiven                 Kudos[]                   @relation("kudosGiven")
  kudosReceived              Kudos[]                   @relation("kudosReceived")
  kudosPromptsAsUser         KudosPrompt[]             @relation("kudosPromptUser")
  kudosPromptsAsRecipient    KudosPrompt[]             @relation("kudosPromptRecipient")
  intentions                 Intention[]

  @@map("users")
}

model EncryptedIdentity {
  id                    String   @id @default(uuid()) @db.Uuid
  userId                String   @unique @map("user_id") @db.Uuid
  encryptedFirstName    String   @map("encrypted_first_name")
  encryptedLastName     String   @map("encrypted_last_name")
  encryptedPersonnummer String   @map("encrypted_personnummer")
  iv                    String
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("encrypted_identities")
}

model Session {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash")
  deviceInfo String?   @map("device_info")
  ipAddress  String?   @map("ip_address")
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  revokedAt  DateTime? @map("revoked_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Payment {
  id             String        @id @default(uuid()) @db.Uuid
  userId         String        @map("user_id") @db.Uuid
  swishPaymentId String?       @unique @map("swish_payment_id")
  amount         Decimal       @db.Decimal(10, 2)
  currency       String        @default("SEK")
  status         PaymentStatus @default(PENDING)
  swishToken     String?       @map("swish_token")
  createdAt      DateTime      @default(now()) @map("created_at")
  completedAt    DateTime?     @map("completed_at")
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Profile {
  id                        String                    @id @default(uuid()) @db.Uuid
  userId                    String                    @unique @map("user_id") @db.Uuid
  displayName               String                    @map("display_name")
  bio                       String?
  age                       Int
  gender                    Gender
  orientation               Orientation
  relationshipType          RelationshipType?         @map("relationship_type")
  seeking                   Seeking[]
  contentPreference         ContentPreference         @map("content_preference")
  verified                  Boolean                   @default(false)
  allowPostEventSuggestions Boolean                   @default(false) @map("allow_post_event_suggestions")
  spicyModeEnabled          Boolean                   @default(false) @map("spicy_mode_enabled")
  createdAt                 DateTime                  @default(now()) @map("created_at")
  updatedAt                 DateTime                  @updatedAt @map("updated_at")
  location                  Unsupported("geography")? @map("location")
  invitationsSent           PairInvitation[]          @relation("invitationsSent")
  invitationsReceived       PairInvitation[]          @relation("invitationsReceived")
  pairLinkMembers           PairLinkMember[]
  kinkTags                  ProfileKinkTag[]
  photos                    ProfilePhoto[]
  prompts                   ProfilePrompt[]
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model ProfilePhoto {
  id              String   @id @default(uuid()) @db.Uuid
  profileId       String   @map("profile_id") @db.Uuid
  url             String
  thumbnailSmall  String?  @map("thumbnail_small")
  thumbnailMedium String?  @map("thumbnail_medium")
  thumbnailLarge  String?  @map("thumbnail_large")
  position        Int      @default(0)
  isPublic        Boolean  @default(true) @map("is_public")
  createdAt       DateTime @default(now()) @map("created_at")
  profile         Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("profile_photos")
}

model ProfilePrompt {
  id        String   @id @default(uuid()) @db.Uuid
  profileId String   @map("profile_id") @db.Uuid
  promptKey String   @map("prompt_key")
  response  String   @db.VarChar(500)
  order     Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, order])
  @@map("profile_prompts")
}

model KinkTag {
  id        String           @id @default(uuid()) @db.Uuid
  name      String           @unique
  category  String
  createdAt DateTime         @default(now()) @map("created_at")
  profiles  ProfileKinkTag[]
  intentions IntentionKinkTag[]

  @@map("kink_tags")
}

model ProfileKinkTag {
  id            String            @id @default(uuid()) @db.Uuid
  profileId     String            @map("profile_id") @db.Uuid
  kinkTagId     String            @map("kink_tag_id") @db.Uuid
  interestLevel KinkInterestLevel @map("interest_level")
  isPublic      Boolean           @default(true) @map("is_public")
  kinkTag       KinkTag           @relation(fields: [kinkTagId], references: [id], onDelete: Cascade)
  profile       Profile           @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, kinkTagId])
  @@map("profile_kink_tags")
}

model PairInvitation {
  id            String           @id @default(uuid()) @db.Uuid
  fromProfileId String           @map("from_profile_id") @db.Uuid
  toProfileId   String           @map("to_profile_id") @db.Uuid
  status        InvitationStatus @default(PENDING)
  createdAt     DateTime         @default(now()) @map("created_at")
  expiresAt     DateTime         @map("expires_at")
  fromProfile   Profile          @relation("invitationsSent", fields: [fromProfileId], references: [id], onDelete: Cascade)
  toProfile     Profile          @relation("invitationsReceived", fields: [toProfileId], references: [id], onDelete: Cascade)

  @@map("pair_invitations")
}

model PairLink {
  id        String           @id @default(uuid()) @db.Uuid
  createdAt DateTime         @default(now()) @map("created_at")
  members   PairLinkMember[]

  @@map("pair_links")
}

model PairLinkMember {
  id         String   @id @default(uuid()) @db.Uuid
  pairLinkId String   @map("pair_link_id") @db.Uuid
  profileId  String   @map("profile_id") @db.Uuid
  joinedAt   DateTime @default(now()) @map("joined_at")
  pairLink   PairLink @relation(fields: [pairLinkId], references: [id], onDelete: Cascade)
  profile    Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([pairLinkId, profileId])
  @@map("pair_link_members")
}

model Post {
  id           String            @id @default(uuid()) @db.Uuid
  authorId     String            @map("author_id") @db.Uuid
  text         String?           @db.VarChar(2000)
  groupId      String?           @map("group_id") @db.Uuid
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  interactions FeedInteraction[]
  media        PostMedia[]
  author       User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  group        Group?            @relation("groupPosts", fields: [groupId], references: [id])

  @@map("posts")
}

model PostMedia {
  id              String       @id @default(uuid()) @db.Uuid
  postId          String       @map("post_id") @db.Uuid
  url             String
  thumbnailSmall  String?      @map("thumbnail_small")
  thumbnailMedium String?      @map("thumbnail_medium")
  thumbnailLarge  String?      @map("thumbnail_large")
  position        Int          @default(0)
  createdAt       DateTime     @default(now()) @map("created_at")
  tags            ContentTag[]
  post            Post         @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("post_media")
}

model ContentTag {
  id          String              @id @default(uuid()) @db.Uuid
  postMediaId String              @map("post_media_id") @db.Uuid
  dimension   ContentTagDimension
  value       String
  confidence  Float               @default(1.0)
  createdAt   DateTime            @default(now()) @map("created_at")
  postMedia   PostMedia           @relation(fields: [postMediaId], references: [id], onDelete: Cascade)

  @@map("content_tags")
}

model UserContentFilter {
  id                 String                  @id @default(uuid()) @db.Uuid
  userId             String                  @unique @map("user_id") @db.Uuid
  nudityLevel        NudityLevel[]           @map("nudity_level")
  bodyPart           BodyPartTag[]           @map("body_part")
  activity           ActivityTag[]
  vibe               VibeTag[]
  genderPresentation GenderPresentationTag[] @map("gender_presentation")
  preset             ContentPreference
  updatedAt          DateTime                @updatedAt @map("updated_at")
  user               User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_content_filters")
}

model FeedInteraction {
  id        String              @id @default(uuid()) @db.Uuid
  userId    String              @map("user_id") @db.Uuid
  postId    String              @map("post_id") @db.Uuid
  type      FeedInteractionType
  createdAt DateTime            @default(now()) @map("created_at")
  post      Post                @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId, type])
  @@map("feed_interactions")
}

model Group {
  id            String           @id @default(uuid()) @db.Uuid
  name          String           @db.VarChar(100)
  description   String?          @db.VarChar(2000)
  category      String           @db.VarChar(100)
  visibility    GroupVisibility  @default(OPEN)
  coverImageUrl String?          @map("cover_image_url")
  createdById   String           @map("created_by_id") @db.Uuid
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  members       GroupMember[]
  moderators    GroupModerator[]
  creator       User             @relation("groupsCreated", fields: [createdById], references: [id], onDelete: Cascade)
  posts         Post[]           @relation("groupPosts")

  @@map("groups")
}

model GroupMember {
  id       String           @id @default(uuid()) @db.Uuid
  groupId  String           @map("group_id") @db.Uuid
  userId   String           @map("user_id") @db.Uuid
  status   MembershipStatus @default(ACTIVE)
  joinedAt DateTime         @default(now()) @map("joined_at")
  group    Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_members")
}

model GroupModerator {
  id         String        @id @default(uuid()) @db.Uuid
  groupId    String        @map("group_id") @db.Uuid
  userId     String        @map("user_id") @db.Uuid
  role       ModeratorRole
  assignedAt DateTime      @default(now()) @map("assigned_at")
  group      Group         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_moderators")
}

model GatekeeperConfig {
  id              String                   @id @default(uuid()) @db.Uuid
  userId          String                   @unique @map("user_id") @db.Uuid
  enabled         Boolean                  @default(true)
  strictness      GatekeeperStrictness     @default(STANDARD)
  customQuestions String[]                 @map("custom_questions")
  dealbreakers    String[]
  aiTone          GatekeeperTone           @default(CASUAL) @map("ai_tone")
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")
  user            User                     @relation("gatekeeperConfig", fields: [userId], references: [id], onDelete: Cascade)
  conversations   GatekeeperConversation[]

  @@map("gatekeeper_configs")
}

model GatekeeperConversation {
  id          String              @id @default(uuid()) @db.Uuid
  senderId    String              @map("sender_id") @db.Uuid
  recipientId String              @map("recipient_id") @db.Uuid
  configId    String              @map("config_id") @db.Uuid
  status      GatekeeperStatus    @default(ACTIVE)
  summary     String?
  tokensCost  Int                 @default(0) @map("tokens_cost")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  config      GatekeeperConfig    @relation(fields: [configId], references: [id], onDelete: Cascade)
  recipient   User                @relation("gatekeeperReceived", fields: [recipientId], references: [id], onDelete: Cascade)
  sender      User                @relation("gatekeeperSent", fields: [senderId], references: [id], onDelete: Cascade)
  messages    GatekeeperMessage[]

  @@index([senderId])
  @@index([recipientId])
  @@map("gatekeeper_conversations")
}

model GatekeeperMessage {
  id             String                 @id @default(uuid()) @db.Uuid
  conversationId String                 @map("conversation_id") @db.Uuid
  role           GatekeeperMessageRole
  content        String
  createdAt      DateTime               @default(now()) @map("created_at")
  conversation   GatekeeperConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("gatekeeper_messages")
}

model UserBalance {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  balance   Decimal  @default(0) @db.Decimal(20, 5)
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_balances")
}

model TokenTransaction {
  id          String               @id @default(uuid()) @db.Uuid
  userId      String               @map("user_id") @db.Uuid
  amount      Decimal              @db.Decimal(20, 5)
  type        TokenTransactionType
  referenceId String?              @map("reference_id") @db.Uuid
  description String?              @map("description")
  serviceRef  String?              @map("service_ref")
  createdAt   DateTime             @default(now()) @map("created_at")
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("token_transactions")
}

model Swipe {
  id        String      @id @default(uuid()) @db.Uuid
  userId    String      @map("user_id") @db.Uuid
  targetId  String      @map("target_id") @db.Uuid
  action    SwipeAction
  createdAt DateTime    @default(now()) @map("created_at")
  target    User        @relation("swipesReceived", fields: [targetId], references: [id], onDelete: Cascade)
  user      User        @relation("swipesSent", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetId])
  @@map("swipes")
}

model Match {
  id           String        @id @default(uuid()) @db.Uuid
  user1Id      String        @map("user1_id") @db.Uuid
  user2Id      String        @map("user2_id") @db.Uuid
  createdAt    DateTime      @default(now()) @map("created_at")
  conversation Conversation?
  kudos        Kudos[]
  kudosPrompts KudosPrompt[]
  user1        User          @relation("matchesAsUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2        User          @relation("matchesAsUser2", fields: [user2Id], references: [id], onDelete: Cascade)

  @@unique([user1Id, user2Id])
  @@map("matches")
}

model SeenProfile {
  id       String   @id @default(uuid()) @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  targetId String   @map("target_id") @db.Uuid
  seenAt   DateTime @default(now()) @map("seen_at")
  target   User     @relation("seenProfileTargets", fields: [targetId], references: [id], onDelete: Cascade)
  user     User     @relation("seenProfiles", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetId])
  @@map("seen_profiles")
}

model Conversation {
  id           String                    @id @default(uuid()) @db.Uuid
  matchId      String                    @unique @map("match_id") @db.Uuid
  createdAt    DateTime                  @default(now()) @map("created_at")
  callSessions CallSession[]
  participants ConversationParticipant[]
  match        Match                     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  messages     Message[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String       @id @default(uuid()) @db.Uuid
  conversationId String       @map("conversation_id") @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  joinedAt       DateTime     @default(now()) @map("joined_at")
  lastReadAt     DateTime?    @map("last_read_at")
  readReceipts   Boolean      @default(true) @map("read_receipts")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@map("conversation_participants")
}

model Message {
  id             String              @id @default(uuid()) @db.Uuid
  conversationId String              @map("conversation_id") @db.Uuid
  senderId       String              @map("sender_id") @db.Uuid
  content        String?
  type           MessageType         @default(TEXT)
  status         MessageStatus       @default(SENT)
  mediaUrl       String?             @map("media_url")
  isFiltered     Boolean             @default(false) @map("is_filtered")
  deletedAt      DateTime?           @map("deleted_at")
  createdAt      DateTime            @default(now()) @map("created_at")
  conversation   Conversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User                @relation(fields: [senderId], references: [id], onDelete: Cascade)
  contentTags    MessageContentTag[]

  @@index([conversationId, createdAt])
  @@map("messages")
}

model CallSession {
  id             String       @id @default(uuid()) @db.Uuid
  conversationId String       @map("conversation_id") @db.Uuid
  initiatorId    String       @map("initiator_id") @db.Uuid
  receiverId     String       @map("receiver_id") @db.Uuid
  callType       CallType     @map("call_type")
  status         CallStatus   @default(RINGING)
  roomName       String       @map("room_name")
  startedAt      DateTime?    @map("started_at")
  endedAt        DateTime?    @map("ended_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  initiator      User         @relation("CallInitiator", fields: [initiatorId], references: [id])
  receiver       User         @relation("CallReceiver", fields: [receiverId], references: [id])

  @@index([conversationId])
  @@map("call_sessions")
}

model Event {
  id                 String                    @id @default(uuid()) @db.Uuid
  createdById        String                    @map("created_by_id") @db.Uuid
  title              String                    @db.VarChar(200)
  description        String?                   @db.VarChar(4000)
  type               EventType
  status             EventStatus               @default(DRAFT)
  startsAt           DateTime                  @map("starts_at")
  endsAt             DateTime?                 @map("ends_at")
  locationName       String?                   @map("location_name") @db.VarChar(500)
  location           Unsupported("geography")? @map("location")
  capacity           Int?
  price              Decimal?                  @db.Decimal(10, 2)
  currency           String                    @default("SEK")
  coverImageUrl      String?                   @map("cover_image_url")
  targetGenders      Gender[]                  @map("target_genders")
  targetOrientations Orientation[]             @map("target_orientations")
  targetMinAge       Int?                      @map("target_min_age")
  targetMaxAge       Int?                      @map("target_max_age")
  createdAt          DateTime                  @default(now()) @map("created_at")
  updatedAt          DateTime                  @updatedAt @map("updated_at")
  attendees          EventAttendee[]
  tickets            EventTicket[]
  creator            User                      @relation("eventsCreated", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([startsAt])
  @@map("events")
}

model EventAttendee {
  id       String         @id @default(uuid()) @db.Uuid
  eventId  String         @map("event_id") @db.Uuid
  userId   String         @map("user_id") @db.Uuid
  status   AttendeeStatus @default(GOING)
  joinedAt DateTime       @default(now()) @map("joined_at")
  event    Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@map("event_attendees")
}

model EventTicket {
  id             String       @id @default(uuid()) @db.Uuid
  eventId        String       @map("event_id") @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  status         TicketStatus @default(VALID)
  swishPaymentId String?      @unique @map("swish_payment_id")
  pricePaid      Decimal      @map("price_paid") @db.Decimal(10, 2)
  currency       String       @default("SEK")
  purchasedAt    DateTime     @default(now()) @map("purchased_at")
  usedAt         DateTime?    @map("used_at")
  refundedAt     DateTime?    @map("refunded_at")
  event          Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user           User         @relation("eventTickets", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@map("event_tickets")
}

model Organization {
  id            String           @id @default(uuid()) @db.Uuid
  name          String           @db.VarChar(200)
  description   String?          @db.VarChar(4000)
  type          OrgType
  locationName  String?          @map("location_name") @db.VarChar(500)
  contactEmail  String?          @map("contact_email")
  contactPhone  String?          @map("contact_phone")
  websiteUrl    String?          @map("website_url")
  coverImageUrl String?          @map("cover_image_url")
  verified      Boolean          @default(false)
  createdById   String           @map("created_by_id") @db.Uuid
  createdAt     DateTime         @default(now()) @map("created_at")
