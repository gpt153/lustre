    "@prisma/client": "^6",
    "@trpc/server": "^11",
    "bcryptjs": "^3.0.3",
    "fastify": "^5",
    "ioredis": "^5.10.1",
    "jose": "^6.2.2",
    "livekit-server-sdk": "^2.15.0",
    "meilisearch": "^0.48",
    "nats": "^2",
    "openai": "^4",
    "sharp": "^0.33",
    "superjson": "^2",
    "twilio": "^5.13.1",
    "zod": "^3.23",
    "@anthropic-ai/sdk": "^0.37.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22",
    "pino-pretty": "^11",
